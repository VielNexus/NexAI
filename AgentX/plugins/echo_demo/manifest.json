{
  "id": "echo_demo",
  "name": "Echo Demo",
  "version": "1.0.0",
  "description": "Example AgentX plugin that exposes a low-risk text tool.",
  "entrypoint": "plugin.py:register",
  "permissions": [
    "text"
  ],
  "risk_level": "low",
  "tools": [
    {
      "name": "demo.echo_upper",
      "description": "Upper-case a text string."
    }
  ],
  "enabled_by_default": false
}
