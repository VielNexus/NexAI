# AgentX local development environment example.
# Copy to .env only for local use. Do not commit real secrets.
# AGENTX_* is preferred. Legacy SOL_* and NEXAI_* names are deprecated fallbacks.

# API bind settings
AGENTX_API_HOST=127.0.0.1
AGENTX_API_PORT=8420

# Local/demo installs normally run without login.
AGENTX_AUTH_ENABLED=false
AGENTX_AUTH_USER=agentx
AGENTX_AUTH_PASSWORD=
AGENTX_AUTH_PASSWORD_SHA256=

# OpenAI-compatible provider. Leave empty unless using OpenAI.
AGENTX_OPENAI_API_KEY=
AGENTX_OPENAI_MODEL=gpt-4o-mini
AGENTX_OPENAI_BASE_URL=https://api.openai.com

# Local Ollama provider.
AGENTX_OLLAMA_BASE_URL=http://127.0.0.1:11434
AGENTX_OLLAMA_REQUEST_TIMEOUT_S=60

# RAG defaults.
AGENTX_RAG_ENABLED=true
AGENTX_RAG_ALLOWED_ROOTS=

# Filesystem and web access are disabled by default for API-level tool paths.
AGENTX_FS_ENABLED=false
AGENTX_FS_ALLOWED_ROOTS=
AGENTX_FS_WRITE_ENABLED=false
AGENTX_FS_DELETE_ENABLED=false
AGENTX_WEB_ENABLED=false
AGENTX_WEB_ALLOWED_HOSTS=
